{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d",
		"name": "UrbanCart API Collection",
		"description": "Collection of API Endpoints for UrbanCart specific to Login, Products, and Orders.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Login API",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"testuser@urbancart.com\",\n  \"password\": \"ValidPass123!\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/auth/login",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Products API",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/products?category=electronics",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"products"
					],
					"query": [
						{
							"key": "category",
							"value": "electronics"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Place Order API",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{jwtToken}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"items\": [\n    {\n      \"productId\": \"1001\",\n      \"quantity\": 2\n    }\n  ],\n  \"shippingAddress\": {\n    \"addressLine1\": \"123 Main St\",\n    \"city\": \"Techville\",\n    \"zipCode\": \"90210\"\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/orders",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"orders"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://api.urbancart-simulated-env.com"
		},
		{
			"key": "jwtToken",
			"value": "sample_token_value_here"
		}
	]
}
